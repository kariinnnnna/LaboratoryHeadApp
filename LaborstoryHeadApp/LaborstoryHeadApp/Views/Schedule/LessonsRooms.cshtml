@{
    ViewData["Title"] = "Расписание по аудиториям";
    Layout = "_Layout";
}

<style>
    :root {
        --galaxy: #0B1F5C;
        --planetary: #334EAC;
        --sky: #D0E3FF;
        --ink: #0f172a;
        --line: rgba(11, 31, 92, .18);
        --card: #ffffff;
        --soft: #f6f8ff;
    }

    /* Заголовок страницы */
    .page-title {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 12px;
    }

    /* Панель управления */
    .sch-topbar {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
        margin-bottom: 14px;
    }

    .sch-left {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .sch-right {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .btn-icon {
        width: 44px;
        height: 38px;
        border: 1px solid var(--line);
        background: #fff;
        color: var(--galaxy);
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: .15s;
    }

        .btn-icon:hover {
            background: var(--soft);
        }

    /* Фильтры */
    .filters {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        align-items: center;
    }

        .filters select {
            height: 38px;
            border: 1px solid var(--line);
            background: #fff;
            padding: 0 10px;
            font-size: 14px;
            min-width: 180px; /* Уменьшаем минимальную ширину */
            border-radius: 10px;
        }

    /* Кнопки */
    .btn-galaxy {
        background-color: var(--galaxy);
        border: 1px solid var(--galaxy);
        color: #fff;
        border-radius: 10px;
        height: 38px;
        padding: 0 14px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        white-space: nowrap;
        transition: .15s;
        text-decoration: none;
    }

        .btn-galaxy:hover {
            background-color: var(--planetary);
            border-color: var(--planetary);
            color: #fff;
        }

    .btn-outline-galaxy {
        color: var(--galaxy);
        border: 1px solid var(--galaxy);
        background: #fff;
        border-radius: 10px;
        height: 38px;
        padding: 0 14px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        white-space: nowrap;
        transition: .15s;
        text-decoration: none;
    }

        .btn-outline-galaxy:hover {
            background: var(--galaxy);
            color: #fff;
        }

    .grid-wrap {
        border: 1px solid var(--line);
        border-radius: 14px;
        padding: 14px;
        background: #fff;
        overflow: visible;
        height: auto;
        box-shadow: 0 1px 2px rgba(0,0,0,.04);
    }

    .table-grid {
        display: grid;
        grid-template-columns: 140px repeat(8, minmax(120px, 1fr));
        gap: 10px;
        align-items: start;
        width: 100%;
    }

    .headcell {
        border: 1px solid var(--line);
        padding: 8px;
        background: #fff;
        text-align: center;
        font-weight: 800;
        border-radius: 12px;
        line-height: 1.2;
        font-size: 11px;
    }

        .headcell small {
            font-weight: 500;
            display: block;
            margin-top: 3px;
            color: #64748b;
            font-size: 11px;
        }

    .rowlabel {
        padding-top: 28px;
        font-size: 14px;
        font-weight: 800;
        color: var(--galaxy);
        white-space: nowrap;
    }

    .slot {
        min-height: 120px;
    }

    .lesson {
        border: 1px solid var(--line);
        padding: 10px;
        background: var(--card);
        border-radius: 12px;
        text-align: left;
        line-height: 1.2;
        box-sizing: border-box;
        box-shadow: 0 1px 2px rgba(0,0,0,.03);
    }

        .lesson .title {
            font-weight: 900;
            margin-bottom: 6px;
            color: #0f172a;
            font-size: 12px;
        }

        .lesson .meta {
            font-size: 12px;
            color: #475569;
        }

    .lesson-accent {
        background: linear-gradient(0deg, rgba(208,227,255,.55), rgba(208,227,255,.55)), #fff;
        border-color: rgba(51,78,172,.35);
    }

    .lesson .type {
        display: inline-flex;
        align-items: center;
        height: 22px;
        padding: 0 8px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 800;
        background: var(--sky);
        color: var(--galaxy);
        margin-bottom: 8px;
    }

</style>

<div class="container py-4">
    <div class="page-title">
        <div>
            <h2 class="mb-1">Расписание занятий по аудиториям</h2>
        </div>

        <a asp-controller="Schedule" asp-action="Index" class="btn btn-outline-galaxy">
            Назад к модулю расписания
        </a>
    </div>

    <!-- TOP BAR -->
    <div class="sch-topbar">
        <div class="sch-left">
            <button class="btn-icon" id="prevDay" title="Назад">‹</button>

            <div class="datebox" title="Дата">
                <input type="date" id="date" />
            </div>

            <button class="btn-icon" id="nextDay" title="Вперёд">›</button>

            <div class="filters">
                <select id="filterRoom">
                    <option value="">Аудитория: все</option>
                </select>

                <select id="filterTeacher">
                    <option value="">Преподаватель: все</option>
                </select>

                <select id="filterGroup">
                    <option value="">Группа: все</option>
                </select>
            </div>
        </div>

        <div class="sch-right">
            <a asp-controller="Schedule" asp-action="SyncLessons" class="btn-galaxy" id="btnSync">
                Запустить синхронизацию
            </a>
            <a asp-controller="ClassroomReservation" asp-action="Create"
               asp-route-date="@ViewBag.Date"
               class="btn btn-outline-galaxy">
                Забронировать аудиторию
            </a>
        </div>
    </div>

    <!-- GRID -->
    <div class="grid-wrap">
        <div class="table-grid" id="table"></div>
    </div>
</div>

@section Scripts {
    <script>
        /* ====== ТЕСТОВЫЕ ДАННЫЕ ====== */
        const pairs = [
            { no: 1, time: "08:30-09:50" },
            { no: 2, time: "10:00-11:20" },
            { no: 3, time: "11:30-12:50" },
            { no: 4, time: "13:30-14:50" },
            { no: 5, time: "15:00-16:20" },
            { no: 6, time: "16:30-17:50" },
            { no: 7, time: "18:00-19:20" },
            { no: 8, time: "19:30-20:50" },
        ];

        const rooms = ["3-411", "3-418/1", "3-418/2", "3-419"];

        const teachers = [
            "Ларионова О Б", "Скалкин А М", "Моисеев В В",
            "Андреев И А", "Ровенская А И", "Чекина А В"
        ];

        const groups = [
            "УПАСбд-42", "УПАСбд-41", "ПИбд-24", "ИСЭбд-41",
            "ИСЭбд-22", "ПИбд-21", "ИСЭбд-21"
        ];

        const lessons = [
            { room: "3-411", pair: 1, type: "лаб", title: "Сетевые технологии в экономике", teacher: "Ларионова О Б", groups: ["УПАСбд-42", "УПАСбд-41"], accent: true },
            { room: "3-411", pair: 2, type: "лаб", title: "Сетевые технологии в экономике", teacher: "Ларионова О Б", groups: ["УПАСбд-42", "УПАСбд-41"], accent: true },

            { room: "3-418/1", pair: 1, type: "лаб", title: "Базы данных", teacher: "Скалкин А М", groups: ["ПИбд-24"], accent: false },
            { room: "3-418/1", pair: 2, type: "лаб", title: "Базы данных", teacher: "Скалкин А М", groups: ["ПИбд-24"], accent: false },
            { room: "3-418/1", pair: 3, type: "лаб", title: "Базы данных", teacher: "Скалкин А М", groups: ["ИСЭбд-22"], accent: false },
            { room: "3-418/1", pair: 4, type: "лаб", title: "Базы данных", teacher: "Скалкин А М", groups: ["ИСЭбд-22"], accent: false },

            { room: "3-418/2", pair: 1, type: "лаб", title: "Информационная безопасность", teacher: "Моисеев В В", groups: ["ИСЭбд-41"], accent: false },
            { room: "3-418/2", pair: 2, type: "лаб", title: "Информационная безопасность", teacher: "Моисеев В В", groups: ["ИСЭбд-41"], accent: false },

            { room: "3-418/3", pair: 2, type: "лаб", title: "Современные сервисные платформенные решения", teacher: "Андреев И А", groups: ["ПИбд-21"], accent: false },
            { room: "3-418/3", pair: 3, type: "лаб", title: "Современные сервисные платформенные решения", teacher: "Андреев И А", groups: ["ПИбд-21"], accent: false },
            { room: "3-418/3", pair: 4, type: "лаб", title: "Организация вычислительных машин и систем", teacher: "Андреев И А", groups: ["ИСЭбд-21"], accent: false },

            { room: "3-419", pair: 2, type: "пр", title: "Основы ПИ", teacher: "Ровенская А И", groups: ["ПИбд-24"], accent: false },
            { room: "3-419", pair: 4, type: "пр", title: "Основы теории систем", teacher: "Чекина А В", groups: ["ИСЭбд-21"], accent: false },
        ];

        /* ====== UI ====== */
        const elTable = document.getElementById("table");
        const elDate = document.getElementById("date");
        const elRoom = document.getElementById("filterRoom");
        const elTeacher = document.getElementById("filterTeacher");
        const elGroup = document.getElementById("filterGroup");
        const elPrev = document.getElementById("prevDay");
        const elNext = document.getElementById("nextDay");

        // дата по умолчанию
        elDate.value = "2025-12-12";

        function fillSelect(el, items) {
            for (const it of items) {
                const opt = document.createElement("option");
                opt.value = it;
                opt.textContent = it;
                el.appendChild(opt);
            }
        }
        fillSelect(elRoom, rooms);
        fillSelect(elTeacher, teachers);
        fillSelect(elGroup, groups);

        function addDays(dateStr, delta) {
            const d = new Date(dateStr + "T00:00:00");
            d.setDate(d.getDate() + delta);
            const yyyy = d.getFullYear();
            const mm = String(d.getMonth() + 1).padStart(2, "0");
            const dd = String(d.getDate()).padStart(2, "0");
            return `${yyyy}-${mm}-${dd}`;
        }

        elPrev.addEventListener("click", () => { elDate.value = addDays(elDate.value, -1); render(); });
        elNext.addEventListener("click", () => { elDate.value = addDays(elDate.value, +1); render(); });

        [elDate, elRoom, elTeacher, elGroup].forEach(x => x.addEventListener("change", render));

        function render() {
            elTable.innerHTML = "";

            // header row (пустая ячейка над аудиториями)
            const empty = document.createElement("div");
            empty.className = "headcell";
            empty.innerHTML = `<div>Аудитории</div><small>${formatDate(elDate.value)}</small>`;
            elTable.appendChild(empty);

            for (const p of pairs) {
                const h = document.createElement("div");
                h.className = "headcell";
                h.innerHTML = `<div>${p.no} пара</div><small>${p.time}</small>`;
                elTable.appendChild(h);
            }

            const fRoom = elRoom.value;
            const fTeacher = elTeacher.value;
            const fGroup = elGroup.value;

            for (const r of rooms) {
                const roomCell = document.createElement("div");
                roomCell.className = "rowlabel";
                roomCell.textContent = r;
                elTable.appendChild(roomCell);

                for (const p of pairs) {
                    const slot = document.createElement("div");
                    slot.className = "slot";

                    const inCell = lessons
                        .filter(x => x.room === r && x.pair === p.no)
                        .filter(x => !fRoom || x.room === fRoom)
                        .filter(x => !fTeacher || x.teacher === fTeacher)
                        .filter(x => !fGroup || x.groups.includes(fGroup));

                    for (const l of inCell) {
                        const card = document.createElement("div");
                        card.className = "lesson" + (l.accent ? " lesson-accent" : "");

                        card.innerHTML = `
                                        <div class="type">${escapeHtml(l.type)}</div>
                                        <div class="title">${escapeHtml(l.title)}</div>
                                        <div class="meta"><b>Ауд.</b> ${escapeHtml(l.room)}</div>
                                        <div class="meta"><b>Преп.</b> ${escapeHtml(l.teacher)}</div>
                                        <div class="meta"><b>Группы:</b> ${escapeHtml(l.groups.join(", "))}</div>
                                    `;
                        slot.appendChild(card);
                    }

                    elTable.appendChild(slot);
                }
            }
        }

        function formatDate(iso) {
            const [y, m, d] = iso.split("-");
            return `${d}.${m}.${y}`;
        }

        function escapeHtml(s) {
            return String(s)
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;")
                .replaceAll("'", "&#039;");
        }

        render();
    </script>
}